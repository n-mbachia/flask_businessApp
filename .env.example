# ==========================================================
# FLASK APPLICATION ENVIRONMENT VARIABLES (Template)
# Copy this file to .env and fill in your actual values.
# NEVER commit .env to version control.
# ==========================================================

# ---------- Flask ----------
FLASK_APP=run.py
FLASK_ENV=production                 # production / development / testing
FLASK_DEBUG=0                         # 0 for production

# ---------- Security ----------
# Generate a strong secret: python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=your-super-secret-key-change-me

# JWT secret (if not set, defaults to SECRET_KEY)
JWT_SECRET_KEY=

# ---------- Database (PostgreSQL) ----------
# Format: postgresql://user:password@host:port/database
DATABASE_URL=postgresql://db_user:db_password@localhost:5432/profitability_db

# ---------- Cache (Redis) ----------
CACHE_TYPE=RedisCache                  # Use RedisCache for production
CACHE_REDIS_URL=redis://:redis_password@localhost:6379/0
CACHE_DEFAULT_TIMEOUT=3600             # 1 hour

# ---------- Rate Limiting (Redis) ----------
RATELIMIT_STORAGE_URL=redis://:redis_password@localhost:6379/1
RATELIMIT_DEFAULT="200 per day, 50 per hour"
RATELIMIT_AUTH_URL="5 per minute"
RATELIMIT_API_URL="100 per hour"

# ---------- Session ----------
SESSION_COOKIE_SECURE=True             # Required for HTTPS
SESSION_COOKIE_SAMESITE=Lax
PERMANENT_SESSION_LIFETIME=7200        # 2 hours

# ---------- Email ----------
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=true
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-app-password
MAIL_DEFAULT_SENDER=your-email@gmail.com

# ---------- Business ----------
SALES_TAX_RATE=0.16                    # 16%
