{
  "name": "business-app",
  "version": "1.0.0",
  "description": "Frontend build for Business App",
  "scripts": {
    "build": "webpack --mode=production",
    "dev": "webpack --watch --mode=development",
    "clean": "rm -rf app/static/dist",
    "build-css": "postcss app/static/css/app.css -o app/static/css/styles.css",
    "watch-css": "postcss app/static/css/app.css -o app/static/css/styles.css --watch",
    "tailwind:build": "npm run build-css",
    "tailwind:watch": "npm run watch-css"
  },
  "dependencies": {
    "bootstrap": "^5.3.0",
    "bootstrap-icons": "^1.10.0",
    "chart.js": "^4.4.0",
    "plotly.js-dist-min": "^2.24.0"
  },
  "devDependencies": {
    "@babel/core": "^7.22.0",
    "@babel/preset-env": "^7.22.0",
    "@tailwindcss/postcss": "^4.2.1",
    "autoprefixer": "^10.4.27",
    "babel-loader": "^9.1.3",
    "copy-webpack-plugin": "^14.0.0",
    "css-loader": "^6.8.0",
    "mini-css-extract-plugin": "^2.7.5",
    "postcss": "^8.5.8",
    "postcss-cli": "^11.0.1",
    "postcss-import": "^16.1.1",
    "postcss-loader": "^8.2.1",
    "sass": "^1.69.5",
    "sass-loader": "^13.3.0",
    "style-loader": "^3.3.3",
    "tailwindcss": "^4.2.1",
    "webpack": "^5.88.0",
    "webpack-cli": "^5.1.4",
    "webpack-merge": "^5.9.0"
  },
  "browserslist": [
    "> 0.2%",
    "not dead",
    "not ie <= 11"
  ],
  "main": "webpack.config.js",
  "directories": {
    "test": "tests"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/n-mbachia/flask_businessApp.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "bugs": {
    "url": "https://github.com/n-mbachia/flask_businessApp/issues"
  },
  "homepage": "https://github.com/n-mbachia/flask_businessApp#readme"
}
